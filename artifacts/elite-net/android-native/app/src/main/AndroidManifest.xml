<?xml version="1.0" encoding="utf-8"?>
<!--
    Elite Net — AndroidManifest.xml
    ================================
    After running `expo prebuild --platform android`, MERGE these entries
    into the generated android/app/src/main/AndroidManifest.xml.

    Google Play 2026 compliance:
      - android:exported declared on every component (required since API 31)
      - No android:protectionLevel on <uses-permission> (invalid attribute)
      - Minimal permissions — only what the app actually uses
      - foregroundServiceType declared for connectedDevice (required API 34+)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.elitenet.vpn">

    <!-- ── Permissions ──────────────────────────────────────────────────────
         Only the permissions the app genuinely needs.
         No protectionLevel on uses-permission — that attribute is only valid
         on <permission> declarations, not <uses-permission>.
    ──────────────────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- VPN tunnel -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Start VPN after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Keep VPN alive in background -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Network state checks -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- ── Application ─────────────────────────────────────────────────────── -->
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/AppTheme">

        <!-- MainActivity is generated by Expo — do not add it here -->

        <!-- ── V2Ray VPN Service ──────────────────────────────────────────
             android:exported="false"  — only this app can start it
             android:permission        — system enforces BIND_VPN_SERVICE
             foregroundServiceType     — required for targetSdk 34+
        ──────────────────────────────────────────────────────────────── -->
        <service
            android:name=".V2RayVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="connectedDevice">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- ── Firebase Cloud Messaging ──────────────────────────────── -->
        <service
            android:name=".EliteFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FCM: default notification channel, icon, colour -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="elite-net-reminders" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <!-- Unity Ads: disable splash (prevents blank-screen on cold start) -->
        <meta-data
            android:name="unity.splash-mode"
            android:value="0" />
        <meta-data
            android:name="unity.splash-enable"
            android:value="False" />

        <!-- ── Boot receiver — restart VPN if phone was rebooted ─────────
             android:exported="true"   — required for BOOT_COMPLETED on API 31+
        ──────────────────────────────────────────────────────────────── -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
